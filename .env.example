# code-robin API Keys
# Copy to ~/.code-robin/.env or run `code-robin configure`
# Only fill in the providers you want to use.

# === International ===
ANTHROPIC_API_KEY=        # Anthropic (Claude)
OPENAI_API_KEY=           # OpenAI (GPT)
GOOGLE_API_KEY=           # Google (Gemini)
GROQ_API_KEY=             # Groq
OPENROUTER_API_KEY=       # OpenRouter (多模型聚合)

# === China / 国内 ===
DEEPSEEK_API_KEY=         # DeepSeek (深度求索)
ZHIPU_API_KEY=            # 智谱 AI (GLM)
DASHSCOPE_API_KEY=        # 通义千问 (Qwen/百炼)
MOONSHOT_API_KEY=         # 月之暗面 (Kimi)
BAICHUAN_API_KEY=         # 百川智能
MINIMAX_API_KEY=          # MiniMax (稀宇)
YI_API_KEY=               # 零一万物 (Yi)
SILICONFLOW_API_KEY=      # 硅基流动 (SiliconFlow)
STEPFUN_API_KEY=          # 阶跃星辰 (StepFun)
SPARK_API_KEY=            # 讯飞星火 (Spark)

# Default provider (name from the list above, e.g. deepseek, qwen, openai)
DEFAULT_PROVIDER=anthropic
